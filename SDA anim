<svg width="800" height="400" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Определяем анимации для морфинга -->
    <style>
      .letter {
        fill: white;
        transform-origin: center;
      }
    </style>
  </defs>
  
  <!-- Буква S (согнутая палка) -->
  <path class="letter letter-s" d="M 80 100 Q 80 150, 120 150 T 120 250 T 80 300">
    <!-- Выпрямление -->
    <animate 
      attributeName="d" 
      from="M 80 100 Q 80 150, 120 150 T 120 250 T 80 300"
      to="M 100 100 L 100 300"
      begin="0s" 
      dur="1s" 
      fill="freeze" />
    
    <!-- Сдвиг влево -->
    <animateTransform
      attributeName="transform"
      type="translate"
      from="0 0"
      to="300 0"
      begin="1s"
      dur="0.8s"
      fill="freeze" />
    
    <!-- Исчезновение (слияние) -->
    <animate
      attributeName="opacity"
      from="1"
      to="0"
      begin="1.6s"
      dur="0.4s"
      fill="freeze" />
  </path>

  <!-- Буква D (согнутая палка) -->
  <path class="letter letter-d" d="M 320 100 Q 380 100, 380 200 Q 380 300, 320 300 L 320 100">
    <!-- Выпрямление -->
    <animate 
      attributeName="d" 
      from="M 320 100 Q 380 100, 380 200 Q 380 300, 320 300 L 320 100"
      to="M 350 100 L 350 300"
      begin="0s" 
      dur="1s" 
      fill="freeze" />
    
    <!-- Сдвиг влево -->
    <animateTransform
      attributeName="transform"
      type="translate"
      from="0 0"
      to="50 0"
      begin="1s"
      dur="0.8s"
      fill="freeze" />
    
    <!-- Остается как основная палка -->
  </path>

  <!-- Буква A (согнутая палка) -->
  <path class="letter letter-a" d="M 580 300 L 620 100 L 660 300">
    <!-- Выпрямление -->
    <animate 
      attributeName="d" 
      from="M 580 300 L 620 100 L 660 300"
      to="M 620 100 L 620 300"
      begin="0s" 
      dur="1s" 
      fill="freeze" />
    
    <!-- Сдвиг влево -->
    <animateTransform
      attributeName="transform"
      type="translate"
      from="0 0"
      to="-220 0"
      begin="1s"
      dur="0.8s"
      fill="freeze" />
    
    <!-- Исчезновение (слияние) -->
    <animate
      attributeName="opacity"
      from="1"
      to="0"
      begin="1.6s"
      dur="0.4s"
      fill="freeze" />
  </path>

  <!-- Расшифровка (появляется в конце) -->
  <text x="450" y="200" fill="white" font-family="Inter, sans-serif" font-size="24" opacity="0">
    <tspan x="450" dy="0">Strategic Digital</tspan>
    <tspan x="450" dy="30">Agency</tspan>
    
    <!-- Появление текста -->
    <animate
      attributeName="opacity"
      from="0"
      to="1"
      begin="2s"
      dur="0.8s"
      fill="freeze" />
    
    <!-- Сдвиг из палки -->
    <animateTransform
      attributeName="transform"
      type="translate"
      from="-50 0"
      to="0 0"
      begin="2s"
      dur="0.8s"
      fill="freeze" />
  </text>
</svg>
